# Copy to .env — see docs/ENVIRONMENT.md for full reference

# Database (PostgreSQL in prod; SQLite default for local dev)
DATABASE_URL=postgresql://autosort:autosort@localhost:5432/autosort

# GitHub OAuth — required for /connect in production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/auth/github/callback

# Signed cookie for onboarding session (change in production)
SESSION_SECRET=change-me-to-random-string

# Stripe pay-as-you-go (optional in dev — local usage counter only without key)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_METER_EVENT_NAME=autosort_files
STRIPE_PRICE_ID=
PRICE_PER_FILE_CENTS=0.1

# URLs for OAuth redirects and CORS
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloud job zip storage
STORAGE_PATH=./packages/api/storage
